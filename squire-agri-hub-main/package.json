  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "vite": "^5.4.2"
  }
}
